{
  "name": "template-foundation-next-pg",
  "version": "1.0.0",
  "description": "Template básica que utiliza next com pg para gerenciar o banco de dados",
  "homepage": "https://github.com/FP-Coding/template-foundation-next-pg#readme",
  "bugs": {
    "url": "https://github.com/FP-Coding/template-foundation-next-pg/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FP-Coding/template-foundation-next-pg.git"
  },
  "license": "MIT",
  "author": "FP-Coding",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run services:wait:database && next dev",
    "test": "npm run services:up && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand --verbose\"",
    "posttest": "npm run services:down",
    "test:watch": "jest --watch --runInBand",
    "services:wait:database": "node infra/scripts/waitForPostgres.js",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down --remove-orphans",
    "migrations:create": "node-pg-migrate create -m infra/migrations",
    "migrations:up": "node-pg-migrate up -m infra/migrations --envPath .env.development",
    "build": "next build",
    "start": "next start",
    "lint:prettier:check": "prettier --check .",
    "lint:eslint:check": "eslint .",
    "dependencies:update": "npx npm-check-updates -i",
    "prepare": "husky"
  },
  "dependencies": {
    "async-retry": "1.3.3",
    "dotenv": "17.4.1",
    "dotenv-expand": "12.0.3",
    "next": "16.2.2",
    "node-pg-migrate": "8.0.4",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-plugin-jest": "29.15.1",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "prettier": "3.8.1"
  }
}
